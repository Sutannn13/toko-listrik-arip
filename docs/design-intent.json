    "button_patterns": {
      "design_system_buttons": {
        "base": "ui-btn",
        "variants": [
          "ui-btn-primary",
          "ui-btn-secondary",
          "ui-btn-soft",
          "ui-btn-success",
          "ui-btn-danger",
          "ui-btn-ghost"
        ]
      },
      "legacy_blade_buttons": [
        "x-primary-button",
        "x-secondary-button",
        "x-danger-button"
      ],
      "button_shape": "rounded-lg",
      "default_button_density": "px-4 py-2.5 text-sm"
    },
    "card_patterns": {
      "primary_card": "ui-card",
      "card_padding_helper": "ui-card-pad",
      "compact_panel": "ui-panel",
      "empty_state": "ui-empty",
      "shape": "rounded-xl to rounded-2xl"
    },
    "form_patterns": {
      "label": "ui-label",
      "input": "ui-input",
      "select": "ui-select",
      "textarea": "ui-textarea",
      "error_render": "x-input-error",
      "focus_pattern": "focus:border-brand-500 + focus:ring-2 focus:ring-brand-500/20"
    },
    "status_patterns": {
      "badge": "ui-badge + semantic variant",
      "alert": "ui-alert + semantic variant",
      "table": "ta-table",
      "admin_navigation": "ta-nav-item + ta-nav-active/ta-nav-idle",
      "admin_dropdown": "ta-dropdown + ta-dropdown-item"
    }
  },
  "responsive_and_interaction": {
    "breakpoint_usage": [
      "sm",
      "md",
      "lg",
      "xl"
    ],
    "mobile_first_rules": [
      "storefront has fixed mobile bottom nav on lg:hidden",
      "main storefront container reserves mobile bottom nav space via pb-24",
      "minimum touch target enforced to 44px on coarse pointers",
      "font-size reduced to 14px for very small screens (max-width 374px)"
    ],
    "motion_patterns": [
      "alpine x-transition enter/leave for modal, dropdown, toast, chat panel",
      "product card hover lift enabled only on hover-capable pointer devices",
      "typing cursor and loading dots in storefront AI assistant"
    ]
  },
  "design_intent": {
    "vibe": "modern-clean-responsive-electric-ecommerce",
    "surface_personality": {
      "storefront": "friendly, promotional, conversion-oriented green accents",
      "admin": "operational dashboard tone with blue semantic hierarchy",
      "auth": "high-contrast image-backed entry funnel"
    },
    "non_negotiable_rules": [
      "use ui-* and ta-* component classes before introducing one-off utility stacks",
      "keep storefront primary actions on primary green scale",
      "keep admin core actions and nav highlights on brand blue scale",
      "do not introduce React-only components without architecture change decision",
      "dark mode changes must preserve class-based strategy and admin scope"
    ]
  },

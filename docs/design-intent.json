      "css_variables": {
        "--ui-brand-navy": "#0b1f3a",
        "--ui-brand-cyan": "#03ac0e",
        "--ui-brand-cyan-soft": "#f2fdf4",
        "--ui-surface": "#ffffff",
        "--ui-border": "#e2e8f0"
      },
      "surface_role_mapping": {
        "storefront_primary_cta": "primary.500-700 (green)",
        "admin_primary_cta": "brand.500-700 (blue)",
        "status_success": "success.50/100/500/700",
        "status_warning": "warning.50/100/500/700",
        "status_error": "error.50/100/500/700",
        "neutral_text_and_surface": "gray.50-900"
      }
    },
    "typography": {
      "font_sources": [
        "Google Fonts (Inter, Plus Jakarta Sans) via resources/css/app.css",
        "Bunny Fonts (Inter, Plus Jakarta Sans/Figtree in legacy layouts)"
      ],
      "font_family_config": {
        "tailwind_body": [
          "Inter",
          "defaultTheme.sans"
        ],
        "tailwind_sans": [
          "Plus Jakarta Sans",
          "Inter",
          "defaultTheme.sans"
        ],
        "base_html": "Plus Jakarta Sans, Inter, Segoe UI, sans-serif",
        "auth_pages_override": "Inter, Segoe UI, sans-serif"
      },
      "tracking": {
        "body_letter_spacing": "0.01em",
        "heading_letter_spacing": "-0.01em"
      },
      "weight_usage": [
        400,
        500,
        600,
        700,
        800,
        900
      ]
    },
    "spacing": {
      "scale_source": "tailwind-default-spacing-scale (no custom extension in tailwind.config.js)",
      "layout_constants": {
        "--ta-sidebar-width": "18.125rem",
        "--ta-header-height": "4rem",
        "--ta-transition": "300ms"
      },
      "most_common_spacing_utilities": [
        "gap-2",
        "gap-3",
        "gap-4",
        "px-3",
        "px-4",
        "px-5",
        "px-6",
        "py-2",
        "py-2.5",
        "py-3",
        "py-4",
        "p-4",
        "p-5",
        "p-6",
        "mb-4",
        "mb-6",
        "mb-8"
      ]
    },
    "border_radius": {
      "global_usage": [
        "rounded-md",
        "rounded-lg",
        "rounded-xl",
        "rounded-2xl",
        "rounded-full"
      ],
      "pattern_mapping": {
        "inputs_buttons": "rounded-lg",
        "panels_alerts_dropdown": "rounded-xl",
        "cards_major_containers": "rounded-2xl",
        "badges_chips_status": "rounded-full"
      }
    },
    "shadows": {
      "tailwind_extended": {
        "tailadmin": "0px 1px 3px rgba(0, 0, 0, 0.08)",
        "tailadmin-md": "0px 4px 6px -1px rgba(0, 0, 0, 0.06)",
        "tailadmin-lg": "0px 10px 15px -3px rgba(0, 0, 0, 0.08)",
        "sidebar": "4px 0 20px rgba(0, 0, 0, 0.08)"
      },
      "usage": "dashboard cards, admin dropdowns, sticky sidebar, storefront product cards"
    },
    "z_index": {
      "sidebar": 40,
      "header": 30,
      "overlay": 50,
      "dropdown": 60,
      "modal": 70,
      "toast": 80
    }
  },
  "dark_mode": {
    "strategy": "class-based",
    "tailwind_config": "darkMode: class",
    "activation": {
      "scope": "admin-layout",
      "mechanism": "alpine state + localStorage darkMode flag + html.dark class",
      "file": "resources/views/layouts/admin.blade.php"
    },
    "coverage": {
      "admin_panel": "full tokenized dark classes (dark:bg-dark-*, dark:border-dark-*)",
      "storefront": "light-first with no user dark toggle",
      "auth": "light-card over dark image overlay"
    }
  },
  "ui_patterns": {

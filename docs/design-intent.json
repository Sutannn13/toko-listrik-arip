{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.0",
  "mode": "dynamic",
  "status": "active",
  "project": {
    "name": "toko-listrik-arip",
    "domain": "laravel-ecommerce-electric-store",
    "frontend_stack": [
      "blade",
      "alpinejs",
      "tailwindcss",
      "vite"
    ],
    "javascript_framework": "alpinejs",
    "react_presence": {
      "enabled": false,
      "jsx_tsx_files_found": 0,
      "react_imports_in_resources_js": 0
    }
  },
  "frontend_architecture": {
    "rendering_model": "server-rendered-blade-templates",
    "interactivity_model": "alpinejs-inline-components-and-transitions",
    "css_architecture": "tailwind-utilities-plus-@layer-base-components-utilities",
    "entrypoints": {
      "css": "resources/css/app.css",
      "js": [
        "resources/js/app.js",
        "resources/js/bootstrap.js"
      ]
    },
    "primary_layouts": [
      "resources/views/layouts/storefront.blade.php",
      "resources/views/layouts/admin.blade.php",
      "resources/views/layouts/guest.blade.php",
      "resources/views/layouts/app.blade.php"
    ],
    "surface_scope": {
      "admin_blade_templates": 14,
      "storefront_blade_templates": 15,
      "auth_templates": "lightweight-tailwind-custom-pages"
    }
  },
  "design_tokens": {
    "colors": {
      "tailwind_extended": {
        "primary": {
          "50": "#f2fdf4",
